# =============================================================================
# .gitignore — JR Validated Environment
# =============================================================================
# NOTE: .Rprofile is intentionally NOT excluded — its contents are deliberate
#       (disables renv auto-activation) and must be version controlled.
# NOTE: .gitignore and .github/ are intentionally NOT excluded.
# NOTE: project_id.txt is intentionally NOT excluded — must be committed so
#       all team members get the correct project identity on clone.
# =============================================================================

# -----------------------------------------------------------------------------
# macOS system files
# -----------------------------------------------------------------------------
.DS_Store
**/.DS_Store
.Spotlight-V100
.Trashes
.fseventsd
.AppleDouble
.LSOverride

# -----------------------------------------------------------------------------
# R / renv auto-generated files
# -----------------------------------------------------------------------------
.Rhistory
**/.Rhistory
.RData
**/.RData
.Rapp.history
**/.Rapp.history

# renv internals — machine-specific, regenerated automatically
renv/
**/renv/

# Auto-generated validation scripts — do not edit manually
# Regenerated by admin_validate via generate_validate_R.zsh
admin/R/validate_R_env.R
admin/Python/validate_Python_env.py

# Plain-text OQ validation report — superseded by OQ_validation_report.docx
docs/OQ_validation_report_20260315.txt

# Local archive folder — not for version control
docs/ignore/

# -----------------------------------------------------------------------------
# Python auto-generated files
# -----------------------------------------------------------------------------
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd
.python-version

# -----------------------------------------------------------------------------
# Admin / machine-specific generated files
# -----------------------------------------------------------------------------
# Integrity file is generated per machine by admin_create_hash
admin/project_integrity.sha256

# -----------------------------------------------------------------------------
# Package repositories
# -----------------------------------------------------------------------------
# These are large binary folders managed via Dropbox, not Git
R_repo/
Python_repo/

# -----------------------------------------------------------------------------
# Build output
# -----------------------------------------------------------------------------
build/*.pkg
build/*.dmg

# -----------------------------------------------------------------------------
# pytest cache
# -----------------------------------------------------------------------------
.pytest_cache/
**/.pytest_cache/

# -----------------------------------------------------------------------------
# Personal / local notes and internal tooling — not for version control
# -----------------------------------------------------------------------------
MANUAL-notes.md
CLAUDE.md
SCRIPT_IDEAS.md
INFRA_BACKLOG.md
docs/*.py
docs/oq_validation_plan.md

# -----------------------------------------------------------------------------
# Microsoft Office temporary lock files
# -----------------------------------------------------------------------------
~$*

# -----------------------------------------------------------------------------
# Editor and IDE files
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
Rplots.pdf
session_log.txt
