#!/bin/bash
#
# jr_app — Launch the JR Anchored graphical interface
#
# Opens a Streamlit-based GUI in your default browser. All scripts
# run through jrrun with the same integrity checking as the CLI.
#
# Usage: jr_app
#
# To stop: close the terminal window, or press Ctrl+C.

set -euo pipefail

# ---------------------------------------------------------------------------
# Resolve paths
# ---------------------------------------------------------------------------

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"
APP_FILE="$PROJECT_ROOT/app/jr_app.py"

# --- Platform helpers
# shellcheck source=jr_platform.sh
source "$SCRIPT_DIR/jr_platform.sh"

# ---------------------------------------------------------------------------
# Check Python
# ---------------------------------------------------------------------------

PYTHON_BIN="python3"
if [[ "$(jr_os)" == "windows" ]]; then
  _py_ver_file="$PROJECT_ROOT/admin/python_version.txt"
  if [[ -f "$_py_ver_file" ]]; then
    _req_mm=$(tr -d '[:space:]' < "$_py_ver_file" | awk -F. '{print $1 "." $2}')
    _py_dir_name="Python$(echo "$_req_mm" | tr -d '.')"
    _win_py="$HOME/AppData/Local/Programs/Python/$_py_dir_name/python.exe"
    [[ -f "$_win_py" ]] && PYTHON_BIN="$_win_py" || PYTHON_BIN="python"
  else
    PYTHON_BIN="python"
  fi
fi

if ! command -v "$PYTHON_BIN" >/dev/null 2>&1; then
  echo "❌ $PYTHON_BIN not found. Install Python first."
  exit 1
fi

# ---------------------------------------------------------------------------
# Check / install Streamlit
# ---------------------------------------------------------------------------

if ! "$PYTHON_BIN" -c "import streamlit" 2>/dev/null; then
  echo "📦 Installing Streamlit (one-time setup)..."
  "$PYTHON_BIN" -m pip install streamlit --quiet
  echo "✅ Streamlit installed."
  echo ""
fi

# ---------------------------------------------------------------------------
# Launch
# ---------------------------------------------------------------------------

# On macOS/Linux: free port 8501 if held by a stale Python/Streamlit process,
# or walk up to 8510 to find an available port.
_find_port() {
  local port=8501
  local max_port=8510
  while [[ $port -le $max_port ]]; do
    if ! lsof -i ":$port" -sTCP:LISTEN -t >/dev/null 2>&1; then
      echo "$port"; return
    fi
    local pids
    pids=$(lsof -i ":$port" -sTCP:LISTEN -t 2>/dev/null || true)
    local freed=false
    for pid in $pids; do
      local comm
      comm=$(ps -p "$pid" -o comm= 2>/dev/null || true)
      if [[ "$comm" == *python* ]] || [[ "$comm" == *streamlit* ]]; then
        echo "⚠️  Port $port held by previous session (PID $pid) — stopping it..." >&2
        kill "$pid" 2>/dev/null && freed=true || true
        sleep 1
      fi
    done
    if $freed && ! lsof -i ":$port" -sTCP:LISTEN -t >/dev/null 2>&1; then
      echo "$port"; return
    fi
    port=$((port + 1))
  done
  echo "error"
}

if [[ "$(jr_os)" == "windows" ]]; then
  PORT=8501
else
  PORT=$(_find_port)
  if [[ "$PORT" == "error" ]]; then
    echo "❌  No available ports found between 8501 and 8510."
    exit 1
  fi
fi

URL="http://localhost:$PORT"

echo ""
echo "⚓ JR Anchored — starting graphical interface..."
echo "   Opening $URL in your browser."
echo "   Press Ctrl+C to stop."
echo ""

# Open browser after a short delay (background, so Streamlit starts immediately)
(
  sleep 2
  if [[ "$(jr_os)" == "windows" ]]; then
    start "$URL" 2>/dev/null
  else
    open "$URL" 2>/dev/null
  fi
) &

exec "$PYTHON_BIN" -m streamlit run "$APP_FILE" \
  --server.port "$PORT" \
  --server.headless true \
  --server.fileWatcherType none \
  --browser.gatherUsageStats false \
  --client.toolbarMode minimal \
  --theme.primaryColor "#2E5BBA"
