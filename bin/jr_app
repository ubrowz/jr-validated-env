#!/bin/bash
#
# jr_app — Launch the JR Anchored graphical interface
#
# Opens a Streamlit-based GUI in your default browser. All scripts
# run through jrrun with the same integrity checking as the CLI.
#
# Usage: jr_app
#
# To stop: close the terminal window, or press Ctrl+C.

set -euo pipefail

# ---------------------------------------------------------------------------
# macOS: re-exec via arch to escape the .app-bundle process context.
#
# When launched from Dock, the nohup background process lives inside the
# .app bundle's TCC context, which can restrict ~/Downloads access for
# child processes (e.g. R scripts saving PNGs). Calling `arch` creates a
# *new subprocess* (arch cannot exec in-place), breaking out of that
# context and giving the new process normal user-session permissions.
#
# Two cases:
#  1. Apple Silicon under Rosetta (x86_64 emulation): re-exec as arm64.
#     Symptom without this: numpy/matplotlib .so files are arm64 but the
#     process is x86_64, causing "incompatible architecture" dlopen errors.
#  2. Intel Mac launched without a TTY (from Dock/app bundle, not Terminal):
#     relaunch through Terminal.app via osascript. arch -x86_64 re-exec does
#     NOT break the TCC responsible-process chain, so ~/Downloads writes by
#     child processes stay blocked. Terminal.app carries the full TCC grants.
# ---------------------------------------------------------------------------
if [[ "$(uname -s)" == "Darwin" ]] && [[ -z "${_JR_ARCH_REEXEC:-}" ]]; then
  _hw_arm64=$(sysctl -n hw.optional.arm64 2>/dev/null || echo 0)
  _proc_arch=$(uname -m)
  if [[ "$_hw_arm64" == "1" ]] && [[ "$_proc_arch" != "arm64" ]]; then
    # Apple Silicon running under Rosetta — force native arm64
    export _JR_ARCH_REEXEC=1
    exec arch -arm64 "$0" "$@"
  elif [[ "$_hw_arm64" != "1" ]] && [[ ! -t 0 ]] && [[ ! -t 1 ]]; then
    # Intel Mac: relaunch through Terminal.app to inherit its TCC permissions
    # (~/Downloads, ~/Desktop, etc.). arch -x86_64 alone does not reset the
    # TCC responsible-process chain when the architecture stays the same.
    export _JR_ARCH_REEXEC=1
    _self="$0"
    osascript -e "tell application \"Terminal\"
      activate
      do script \"exec $(printf '%q' "$_self")\"
    end tell" 2>/dev/null && exit 0
    # osascript unavailable — fall back to arch re-exec (TCC issue persists)
    exec arch -x86_64 "$_self" "$@"
  fi
fi

# ---------------------------------------------------------------------------
# Resolve paths
# ---------------------------------------------------------------------------

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"
APP_FILE="$PROJECT_ROOT/app/jr_app.py"

# --- Platform helpers
# shellcheck source=jr_platform.sh
source "$SCRIPT_DIR/jr_platform.sh"

# ---------------------------------------------------------------------------
# Check Python
# ---------------------------------------------------------------------------

PYTHON_BIN="python3"
if [[ "$(jr_os)" == "windows" ]]; then
  _py_ver_file="$PROJECT_ROOT/admin/python_version.txt"
  if [[ -f "$_py_ver_file" ]]; then
    _req_mm=$(tr -d '[:space:]' < "$_py_ver_file" | awk -F. '{print $1 "." $2}')
    _py_dir_name="Python$(echo "$_req_mm" | tr -d '.')"
    _win_py="$HOME/AppData/Local/Programs/Python/$_py_dir_name/python.exe"
    [[ -f "$_win_py" ]] && PYTHON_BIN="$_win_py" || PYTHON_BIN="python"
  else
    PYTHON_BIN="python"
  fi
fi

if ! command -v "$PYTHON_BIN" >/dev/null 2>&1; then
  echo "❌ $PYTHON_BIN not found. Install Python first."
  exit 1
fi

# ---------------------------------------------------------------------------
# Check / install Streamlit
# ---------------------------------------------------------------------------

if ! "$PYTHON_BIN" -c "import streamlit" 2>/dev/null; then
  echo "📦 Installing Streamlit (one-time setup)..."
  "$PYTHON_BIN" -m pip install streamlit --quiet
  echo "✅ Streamlit installed."
  echo ""
fi

# ---------------------------------------------------------------------------
# Launch
# ---------------------------------------------------------------------------

# On macOS/Linux: free port 8501 if held by a stale Python/Streamlit process,
# or walk up to 8510 to find an available port.
_find_port() {
  local port=8501
  local max_port=8510
  while [[ $port -le $max_port ]]; do
    if ! lsof -i ":$port" -sTCP:LISTEN -t >/dev/null 2>&1; then
      echo "$port"; return
    fi
    local pids
    pids=$(lsof -i ":$port" -sTCP:LISTEN -t 2>/dev/null || true)
    local freed=false
    for pid in $pids; do
      local comm
      comm=$(ps -p "$pid" -o comm= 2>/dev/null || true)
      if [[ "$comm" == *python* ]] || [[ "$comm" == *streamlit* ]]; then
        echo "⚠️  Port $port held by previous session (PID $pid) — stopping it..." >&2
        kill "$pid" 2>/dev/null && freed=true || true
        sleep 1
      fi
    done
    if $freed && ! lsof -i ":$port" -sTCP:LISTEN -t >/dev/null 2>&1; then
      echo "$port"; return
    fi
    port=$((port + 1))
  done
  echo "error"
}

if [[ "$(jr_os)" == "windows" ]]; then
  PORT=8501
else
  PORT=$(_find_port)
  if [[ "$PORT" == "error" ]]; then
    echo "❌  No available ports found between 8501 and 8510."
    exit 1
  fi
fi

URL="http://localhost:$PORT"

echo ""
echo "⚓ JR Anchored — starting graphical interface..."
echo "   Opening $URL in your browser."
echo "   Press Ctrl+C to stop."
echo ""

# Open browser after a short delay (background, so Streamlit starts immediately)
(
  sleep 2
  if [[ "$(jr_os)" == "windows" ]]; then
    start "$URL" 2>/dev/null
  else
    open "$URL" 2>/dev/null
  fi
) &

exec "$PYTHON_BIN" -m streamlit run "$APP_FILE" \
  --server.port "$PORT" \
  --server.headless true \
  --server.fileWatcherType none \
  --browser.gatherUsageStats false \
  --client.toolbarMode minimal \
  --theme.primaryColor "#2E5BBA"
