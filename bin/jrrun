#!/bin/bash
set -e
#
# jrrun
# Executes a validated R or Python script in the controlled environment.
#
# Usage:
#   jrrun <script.[R|py]> [arguments...]
#   jrrun -h | --help
#

# --- Capture launch directory before cd
CALL_DIR="$PWD"

# --- Directories
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"   # = bin/
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"        # = project root

# --- Platform helpers
# shellcheck source=bin/jr_platform.sh
source "$SCRIPT_DIR/jr_platform.sh"
cd "$PROJECT_ROOT" || exit 1
ADMIN_HOME="$PROJECT_ROOT/admin"

# --- Project identity
PROJECT_ID_FILE="$ADMIN_HOME/project_id.txt"
if [[ ! -f "$PROJECT_ID_FILE" ]]; then
  echo "❌ project_id.txt not found at: $PROJECT_ID_FILE"
  echo "   Contact your administrator."
  exit 1
fi
PROJECT_ID="$(tr -d '[:space:]' < "$PROJECT_ID_FILE")"

# --- Help
show_help() {
  HELP_FILE="$PROJECT_ROOT/help/jrrun.txt"
  if [[ -f "$HELP_FILE" ]]; then
    cat "$HELP_FILE"
  else
    echo ""
    echo "Usage: jrrun <script.[R|py]> [arguments...]"
    echo ""
    echo "Description:"
    echo "  Executes an R (.R) or Python (.py) script in the validated"
    echo "  environment. The script must be in the R/ or Python/ subfolder,"
    echo "  or specified as a path relative to the current directory."
    echo ""
    echo "Arguments:"
    echo "  script.[R|py]  Script filename or path. Extension determines"
    echo "                 which environment is used."
    echo "  arguments      Optional arguments passed through to the script."
    echo "  -h | --help    Show this help message."
    echo ""
    echo "Examples:"
    echo "  jrrun myscript.R \"arg1\" \"arg2\""
    echo "  jrrun myscript.py \"arg1\""
    echo "  jrrun R/myscript.R \"arg1\""
    echo ""
    echo "Per-script help (if available):"
    echo "  jrrun myscript.R --help"
    echo ""
  fi
  exit 0
}

# --- Handle no arguments or top-level help
if [[ $# -eq 0 ]]; then
  show_help
fi
if [[ "$1" == "-h" || "$1" == "--help" ]]; then
  show_help
fi

# --- Resolve script path
if [[ "$1" = /* ]]; then
  # Absolute path — use as-is
  TARGET_SCRIPT="$1"
elif [[ "$1" == */* ]]; then
  # Relative path with directory component — resolve from CALL_DIR
  TARGET_SCRIPT="$CALL_DIR/$1"
else
  # Bare filename — look in core subfolder first, then search repos/*/
  case "$1" in
    *.R)
      if [[ -f "$PROJECT_ROOT/R/$1" ]]; then
        TARGET_SCRIPT="$PROJECT_ROOT/R/$1"
      else
        for _repo_dir in "$PROJECT_ROOT/repos"/*/R; do
          if [[ -f "$_repo_dir/$1" ]]; then TARGET_SCRIPT="$_repo_dir/$1"; break; fi
        done
      fi
      if [[ -z "$TARGET_SCRIPT" ]]; then
        echo "❌ Script not found: $1"
        echo "   Searched: $PROJECT_ROOT/R/ and $PROJECT_ROOT/repos/*/R/"
        exit 1
      fi
      ;;
    *.py)
      if [[ -f "$PROJECT_ROOT/Python/$1" ]]; then
        TARGET_SCRIPT="$PROJECT_ROOT/Python/$1"
      else
        for _repo_dir in "$PROJECT_ROOT/repos"/*/Python; do
          if [[ -f "$_repo_dir/$1" ]]; then TARGET_SCRIPT="$_repo_dir/$1"; break; fi
        done
      fi
      if [[ -z "$TARGET_SCRIPT" ]]; then
        echo "❌ Script not found: $1"
        echo "   Searched: $PROJECT_ROOT/Python/ and $PROJECT_ROOT/repos/*/Python/"
        exit 1
      fi
      ;;
    *)    TARGET_SCRIPT="$CALL_DIR/$1" ;;
  esac
fi

# --- Detect language from extension
case "$TARGET_SCRIPT" in
  *.R)  LANG="R"      ;;
  *.py) LANG="python" ;;
  *)
    echo "❌ Cannot determine language from filename: $(basename "$TARGET_SCRIPT")"
    echo "   Script must have a .R or .py extension."
    exit 1
    ;;
esac

shift   # remaining $@ are arguments to the script

# --- Per-script help: forward --help to the script's help file if present
for arg in "$@"; do
  if [[ "$arg" == "-h" || "$arg" == "--help" ]]; then
    _script_name="$(basename "${TARGET_SCRIPT%.*}")"
    SCRIPT_HELP="$PROJECT_ROOT/help/${_script_name}.txt"
    if [[ ! -f "$SCRIPT_HELP" ]]; then
      for _repo_dir in "$PROJECT_ROOT/repos"/*/help; do
        if [[ -f "$_repo_dir/${_script_name}.txt" ]]; then
          SCRIPT_HELP="$_repo_dir/${_script_name}.txt"; break
        fi
      done
    fi
    if [[ -f "$SCRIPT_HELP" ]]; then
      cat "$SCRIPT_HELP"
      exit 0
    else
      echo "ℹ️  No help file found for $(basename "$TARGET_SCRIPT")"
      echo "   Expected: $PROJECT_ROOT/help/${_script_name}.txt"
      exit 0
    fi
  fi
done

# --- Check script exists
if [[ ! -f "$TARGET_SCRIPT" ]]; then
  echo "❌ Script not found: $TARGET_SCRIPT"
  exit 1
fi
echo "✅ Script found: $TARGET_SCRIPT"

# --- Verify project integrity
if [[ ! -f "$ADMIN_HOME/project_integrity.sha256" ]]; then
  echo "❌ Integrity file missing. Contact admin."
  exit 1
fi
echo "🔎 Verifying project integrity..."
if ! shasum -a 256 -c "$ADMIN_HOME/project_integrity.sha256" >/dev/null 2>&1; then
  echo ""
  echo "❌ PROJECT INTEGRITY CHECK FAILED"
  echo "   One or more files were modified. Contact admin."
  echo ""
  exit 1
fi
echo "✅ Integrity verified"

# ===========================================================================
# R branch
# ===========================================================================
if [[ "$LANG" == "R" ]]; then

  export RENV_HOME="$HOME/.renv/$PROJECT_ID"
  export RENV_PATHS_ROOT="$HOME/.renv/$PROJECT_ID"
  export JR_R_PLATFORM_DIR="$(jr_r_platform_dir)"
  export LOCAL_REPO="$PROJECT_ROOT/R_repo/my-cran-repo"
  unset R_LIBS
  unset R_LIBS_USER
  unset R_LIBS_SITE

  LOCK_FILE="$ADMIN_HOME/renv.lock"
  if [[ ! -f "$LOCK_FILE" ]]; then
    echo "❌ renv.lock not found. Contact admin."
    exit 1
  fi

  REQ_HASH=$(shasum "$LOCK_FILE" | cut -d' ' -f1)
  HASH_FILE="$RENV_HOME/.renv_lock_hash"
  RENV_LIB=$(find "$RENV_HOME/renv/library" -mindepth 3 -maxdepth 3 \
             -type d 2>/dev/null | head -1)
  NEED_REBUILD=false
  if [[ ! -d "$RENV_HOME" ]]; then
    NEED_REBUILD=true
  elif [[ -z "$RENV_LIB" ]]; then
    NEED_REBUILD=true
  elif [[ ! -f "$HASH_FILE" ]]; then
    NEED_REBUILD=true
  elif [[ "$(cat "$HASH_FILE")" != "$REQ_HASH" ]]; then
    NEED_REBUILD=true
  fi

  if $NEED_REBUILD; then
    if [[ ! -d "$LOCAL_REPO" ]]; then
      echo "❌ Local R package repo not found at: $LOCAL_REPO"
      echo "   Ensure Dropbox is synced or contact admin."
      exit 1
    fi
    echo "🔄 (Re)creating R environment..."
    rm -rf "$RENV_HOME"
    mkdir -p "$RENV_HOME"

    # Convert paths for R: on Windows Git Bash paths (/c/Users/...) must be
    # converted to Windows paths (C:/Users/...) before passing to R.
    if [[ "$(jr_os)" == "windows" ]]; then
      R_LOCAL_REPO_URL="file:///$(cygpath -w "$LOCAL_REPO" | tr '\\' '/')"
      R_RENV_HOME="$(cygpath -w "$RENV_HOME" | tr '\\' '/')"
      R_LOCK_FILE="$(cygpath -w "$LOCK_FILE" | tr '\\' '/')"
    else
      R_LOCAL_REPO_URL="file://$LOCAL_REPO"
      R_RENV_HOME="$RENV_HOME"
      R_LOCK_FILE="$LOCK_FILE"
    fi

    Rscript --vanilla - <<EOF
local_repo <- "$R_LOCAL_REPO_URL"
options(repos    = c(LOCAL = local_repo),
        pkgType  = "binary",
        install.packages.compile.from.source = "never")
install.packages("renv", repos = local_repo)
Sys.setenv(RENV_PATHS_ROOT = "$R_RENV_HOME")
renv::init(project  = "$R_RENV_HOME",
           bare     = TRUE,
           restart  = FALSE)
renv::restore(project  = "$R_RENV_HOME",
              lockfile = "$R_LOCK_FILE",
              repos    = c(LOCAL = local_repo),
              prompt   = FALSE)
EOF
    echo "$REQ_HASH" > "$HASH_FILE"
  fi

  # --- Run log setup
  LOG_FILE="$HOME/.jrscript/$PROJECT_ID/run.log"
  mkdir -p "$(dirname "$LOG_FILE")"

  # --- Run R script
  Rscript --vanilla "$TARGET_SCRIPT" "$@"
  EXIT_CODE=$?
  printf '%s\t%s\t%s\t%s\n' \
    "$(date '+%Y-%m-%dT%H:%M:%S')" \
    "jrrun" \
    "$(basename "$TARGET_SCRIPT") $*" \
    "$EXIT_CODE" >> "$LOG_FILE"
  exit $EXIT_CODE

fi

# ===========================================================================
# Python branch
# ===========================================================================
if [[ "$LANG" == "python" ]]; then

  export VENV_PATH="$HOME/.venvs/$PROJECT_ID"
  export LOCAL_REPO="$PROJECT_ROOT/Python_repo/my-repo"
  export PYTHONUTF8=1
  unset PYTHONPATH
  unset PYTHONHOME

  REQ_HASH=$(shasum "$ADMIN_HOME/python_requirements.txt" | cut -d' ' -f1)
  HASH_FILE="$VENV_PATH/.req_hash"
  NEED_REBUILD=false
  if [[ ! -f "$HASH_FILE" ]]; then
    NEED_REBUILD=true
  elif [[ "$(cat "$HASH_FILE")" != "$REQ_HASH" ]]; then
    NEED_REBUILD=true
  fi

  if $NEED_REBUILD; then
    if [[ ! -d "$LOCAL_REPO" ]]; then
      echo "❌ Local Python repo not found at: $LOCAL_REPO"
      echo "   Ensure Dropbox is synced or contact admin."
      exit 1
    fi
    PY_VERSION_FILE="$ADMIN_HOME/python_version.txt"
    if [[ ! -f "$PY_VERSION_FILE" ]]; then
      echo "❌ python_version.txt missing. Contact admin."
      exit 1
    fi
    REQ_PYTHON="$(tr -d '[:space:]' < "$PY_VERSION_FILE")"
    REQ_MAJOR_MINOR=$(echo "$REQ_PYTHON" | awk -F. '{print $1 "." $2}')
    if [[ "$(jr_os)" == "windows" ]]; then
      PYTHON_BIN="python"
    else
      PYTHON_BIN="python$REQ_MAJOR_MINOR"
    fi
    if ! command -v "$PYTHON_BIN" >/dev/null 2>&1; then
      echo "❌ $PYTHON_BIN not found. Contact admin."
      exit 1
    fi
    echo "🔄 (Re)creating Python environment..."
    rm -rf "$VENV_PATH"
    "$PYTHON_BIN" -m venv "$VENV_PATH"
    "$(jr_venv_pip "$VENV_PATH")" install \
      --no-index \
      --find-links "$LOCAL_REPO" \
      -r "$ADMIN_HOME/python_requirements.txt"
    echo "$REQ_HASH" > "$HASH_FILE"
  fi

  # --- Run log setup
  LOG_FILE="$HOME/.jrscript/$PROJECT_ID/run.log"
  mkdir -p "$(dirname "$LOG_FILE")"

  # --- Run Python script
  "$(jr_venv_python "$VENV_PATH")" "$TARGET_SCRIPT" "$@"
  EXIT_CODE=$?
  printf '%s\t%s\t%s\t%s\n' \
    "$(date '+%Y-%m-%dT%H:%M:%S')" \
    "jrrun" \
    "$(basename "$TARGET_SCRIPT") $*" \
    "$EXIT_CODE" >> "$LOG_FILE"
  exit $EXIT_CODE

fi
