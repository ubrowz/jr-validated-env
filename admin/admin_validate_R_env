#!/bin/bash
#
# validate_R_env
# Runs the generated R validation script.
# Use during audits to prove correct packages are installed.
#

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR" || exit 1
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"

# --- Platform helpers
# shellcheck source=../bin/jr_platform.sh
source "$PROJECT_ROOT/bin/jr_platform.sh"
export JR_R_PLATFORM_DIR="$(jr_r_platform_dir)"

# --- Project identity — read from project_id.txt (one line change per fork)
PROJECT_ID_FILE="$SCRIPT_DIR/project_id.txt"
if [[ ! -f "$PROJECT_ID_FILE" ]]; then
  echo "❌ project_id.txt not found at: $PROJECT_ID_FILE"
  echo "   Contact your administrator."
  exit 1
fi
PROJECT_ID="$(tr -d '[:space:]' < "$PROJECT_ID_FILE")"

RENV_HOME="$HOME/.renv/$PROJECT_ID"
unset R_LIBS
unset R_LIBS_USER
unset R_LIBS_SITE

# --- Ensure Rscript is on PATH (Windows: auto-detect if missing)
if ! command -v Rscript >/dev/null 2>&1; then
  if [[ "$(jr_os)" == "windows" ]]; then
    R_BIN_DIR=""
    for r_dir in "/c/Program Files/R"/R-*/; do
      [[ -f "${r_dir}bin/Rscript.exe" ]] && R_BIN_DIR="${r_dir}bin"
    done
    if [[ -n "$R_BIN_DIR" ]]; then
      export PATH="$R_BIN_DIR:$PATH"
    else
      echo "❌ Rscript not found. Install R and ensure it is on your PATH."
      exit 1
    fi
  else
    echo "❌ Rscript not found."
    exit 1
  fi
fi

if [[ ! -f "$SCRIPT_DIR/R/validate_R_env.R" ]]; then
  echo "❌ validate_R_env.R not found."
  echo "   Run generate_validate_R.zsh first."
  exit 1
fi

# On Windows convert Git Bash path to Windows-native path so R can resolve it.
# Inject paths directly via Sys.setenv in a heredoc (same technique as jrrun)
# to prevent renv or any R startup code from overriding the env var.
if [[ "$(jr_os)" == "windows" ]]; then
  R_RENV_HOME="$(cygpath -w "$RENV_HOME" | tr '\\' '/')"
  R_VALIDATE_SCRIPT="$(cygpath -w "$SCRIPT_DIR/R/validate_R_env.R" | tr '\\' '/')"
else
  R_RENV_HOME="$RENV_HOME"
  R_VALIDATE_SCRIPT="$SCRIPT_DIR/R/validate_R_env.R"
fi

Rscript --vanilla - <<EOF
Sys.setenv(RENV_PATHS_ROOT   = "$R_RENV_HOME")
Sys.setenv(JR_R_PLATFORM_DIR = "$JR_R_PLATFORM_DIR")
source("$R_VALIDATE_SCRIPT")
EOF
