#!/bin/bash
set -e
#
# admin_install_R
# Sets up the validated R environment.
#
# Usage:
#   admin_install_R              — install from existing local repo
#   admin_install_R --rebuild    — download all packages from internet, then install
#   admin_install_R --add packagename==version
#                                — add one package to existing repo, then install
#

# --- Script directory (admin/)
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR" || exit 1
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"

# --- Platform helpers
# shellcheck source=../bin/jr_platform.sh
source "$PROJECT_ROOT/bin/jr_platform.sh"

# --- Project identity
PROJECT_ID_FILE="$SCRIPT_DIR/project_id.txt"
if [[ ! -f "$PROJECT_ID_FILE" ]]; then
  echo "❌ project_id.txt not found at: $PROJECT_ID_FILE"
  echo "   Contact your administrator."
  exit 1
fi
PROJECT_ID="$(tr -d '[:space:]' < "$PROJECT_ID_FILE")"

# --- R environment paths
export RENV_HOME="$HOME/.renv/$PROJECT_ID"
export RENV_PATHS_ROOT="$HOME/.renv/$PROJECT_ID"
export LOCAL_REPO="$PROJECT_ROOT/R_repo/my-cran-repo"
export BUILD_REPO="false"
export ADD_PACKAGE=""

# --- Detect platform for R binary package paths
# Ask R itself for the contrib URL — it knows the correct platform for its build.
# Fallback to architecture-based defaults if R is not yet on PATH.
if [[ "$(jr_os)" == "windows" ]]; then
  export R_MACOS_PLATFORM="windows"
else
  _cran_platform=$(Rscript --vanilla -e \
    'u <- contrib.url("https://cloud.r-project.org", type="binary"); cat(sub("^.*/macosx/([^/]+)/.*$", "\\1", u))' \
    2>/dev/null || true)
  if [[ "$_cran_platform" =~ ^[a-z] ]]; then
    export R_MACOS_PLATFORM="$_cran_platform"
  elif [[ "$(uname -m)" == "arm64" ]]; then
    export R_MACOS_PLATFORM="sonoma-arm64"
  else
    export R_MACOS_PLATFORM="big-sur-x86_64"
  fi
fi
export JR_R_PLATFORM_DIR="$(jr_r_platform_dir)"

# --- Clear R library overrides
unset R_LIBS
unset R_LIBS_USER
unset R_LIBS_SITE

# --- Check required files exist
R_VERSION_FILE="$SCRIPT_DIR/r_version.txt"
if [[ ! -f "$R_VERSION_FILE" ]]; then
  echo "❌ r_version.txt missing. Contact admin."
  exit 1
fi
if [[ ! -f "$SCRIPT_DIR/R_requirements.txt" ]]; then
  echo "❌ R_requirements.txt missing. Contact admin."
  exit 1
fi

# --- Check R is installed; on Windows auto-detect and add to PATH if missing
if ! command -v Rscript >/dev/null 2>&1; then
  if [[ "$(jr_os)" == "windows" ]]; then
    R_BIN_DIR=""
    for r_dir in "/c/Program Files/R"/R-*/; do
      [[ -f "${r_dir}bin/Rscript.exe" ]] && R_BIN_DIR="${r_dir}bin"
    done
    if [[ -n "$R_BIN_DIR" ]]; then
      echo "📍 Rscript not on PATH — found R at: $R_BIN_DIR"
      echo "   Adding to ~/.bash_profile and current session..."
      echo "export PATH=\"$R_BIN_DIR:\$PATH\"" >> "$HOME/.bash_profile"
      export PATH="$R_BIN_DIR:$PATH"
      echo "✅ R added to PATH."
      echo ""
    else
      echo "❌ Rscript not found and R not detected in /c/Program Files/R/."
      echo "   Install R and re-run this script."
      exit 1
    fi
  else
    echo "❌ Rscript not found."
    echo "   Install R from: $PROJECT_ROOT/R_repo/"
    exit 1
  fi
fi

# --- Check R version matches requirement
REQ_R="$(cat "$R_VERSION_FILE")"
if ! R_VER=$(Rscript --vanilla -e 'cat(format(getRversion(), nsmall = 1))' 2>/dev/null); then
  echo "❌ Failed to detect R version."
  exit 1
fi
R_VER=$(echo "$R_VER" | cut -d. -f1,2)
if [[ "$R_VER" != "$REQ_R" ]]; then
  echo ""
  echo "❌ Wrong R version installed."
  echo "   Required : R $REQ_R  (admin/r_version.txt)"
  echo "   Installed: R $R_VER"
  echo ""
  echo "   Download R $REQ_R from https://cran.r-project.org"
  if [[ "$(jr_os)" == "windows" ]]; then
    echo "   On Windows: uninstall R $R_VER via Add/Remove Programs first."
  fi
  echo ""
  echo "   ⚠️  To use a different R version, update admin/r_version.txt and"
  echo "   re-run the full OQ qualification suite before validated use."
  echo ""
  exit 1
fi

# --- Argument parsing
SKIP_NEXT=false
for arg in "$@"; do
  if [[ "$SKIP_NEXT" == "true" ]]; then
    export ADD_PACKAGE="$arg"
    SKIP_NEXT=false
    continue
  fi
  case "$arg" in
    --rebuild)
      export BUILD_REPO="true"
      ;;
    --add)
      SKIP_NEXT=true
      ;;
    --add=*)
      export ADD_PACKAGE="${arg#--add=}"
      ;;
    --help|-h)
      echo ""
      echo "Usage: admin_install_R [--rebuild] [--add packagename==version]"
      echo ""
      echo "  (no flag)                  Install from existing local repo"
      echo "  --rebuild                  Download all packages from internet, then install"
      echo "  --add packagename==version Add one package to existing repo, then install"
      echo ""
      echo "Examples:"
      echo "  admin_install_R"
      echo "  admin_install_R --rebuild"
      echo "  admin_install_R --add fitdistrplus==1.1-11"
      echo ""
      exit 0
      ;;
    *)
      echo "❌ Unknown argument: $arg"
      exit 1
      ;;
  esac
done

# --- Validate --add format if provided
if [[ -n "$ADD_PACKAGE" ]]; then
  if [[ "$ADD_PACKAGE" != *"=="* ]]; then
    echo "❌ --add requires format: packagename==version"
    echo "   Example: admin_install_R --add fitdistrplus==1.1-11"
    exit 1
  fi
  echo "➕ Adding package: $ADD_PACKAGE"
fi

# --- Confirm mode
if [[ "$BUILD_REPO" == "true" ]]; then
  echo "🔨 Mode: full rebuild from internet"
elif [[ -n "$ADD_PACKAGE" ]]; then
  echo "➕ Mode: add package to existing repo"
else
  echo "📂 Mode: install from existing local repo"
fi
echo ""

# --- Local repository integrity check
# Works for any delivery mechanism (Dropbox, SMB, NFS, etc.).
# Skip for --rebuild (downloads fresh) and --add (fetches new package from internet).
if [[ "$BUILD_REPO" != "true" && -z "$ADD_PACKAGE" ]]; then
  echo "🔍 Checking local repository integrity..."
  REPO_OK=true

  if [[ ! -d "$LOCAL_REPO" ]]; then
    echo "❌ Local R repository not found: $LOCAL_REPO"
    echo "   Ensure the repository folder is present. Expected: R_repo/my-cran-repo/"
    echo "   To rebuild from the internet: admin_install_R --rebuild"
    exit 1
  fi

  # Dropbox leaves "* conflicted copy *" files on sync conflicts.
  CONFLICT_FILES="$(find "$LOCAL_REPO" -name "* conflicted copy *" 2>/dev/null | head -5)"
  if [[ -n "$CONFLICT_FILES" ]]; then
    echo "⚠️  Sync conflict files detected in the repository:"
    while IFS= read -r f; do echo "   $f"; done <<< "$CONFLICT_FILES"
    echo "   Resolve all conflicts before installing."
    REPO_OK=false
  fi

  if ! find "$LOCAL_REPO" -name "PACKAGES" 2>/dev/null | grep -q .; then
    echo "❌ No PACKAGES index found in: $LOCAL_REPO"
    echo "   Repository may be incomplete or still syncing."
    REPO_OK=false
  fi

  while IFS= read -r line || [[ -n "$line" ]]; do
    line=$(echo "$line" | tr -d '[:space:]')
    [[ -z "$line" || "$line" == \#* ]] && continue
    pkg="${line%%==*}"
    ver="${line##*==}"
    if ! find "$LOCAL_REPO" -name "${pkg}_${ver}*" 2>/dev/null | grep -q .; then
      echo "❌ Package file not found in repository: ${pkg}==${ver}"
      echo "   Run: admin_install_R --add ${pkg}==${ver}"
      REPO_OK=false
    fi
  done < "$SCRIPT_DIR/R_requirements.txt"

  if [[ "$REPO_OK" == "false" ]]; then
    echo ""
    echo "   Repository integrity check FAILED. Aborting."
    exit 1
  fi
  echo "✅ Repository integrity check passed."
  echo ""
fi

# --- Admin log setup
ADMIN_LOG_FILE="$HOME/.jrscript/$PROJECT_ID/admin.log"
mkdir -p "$(dirname "$ADMIN_LOG_FILE")"

# Convert paths for R on Windows: Git Bash Unix paths (/c/Users/...) are not
# resolved by R.exe (a Windows native binary). Convert to Windows-native paths
# (C:/Users/...) before the env vars are read by admin_R_install.R.
if [[ "$(jr_os)" == "windows" ]]; then
  export RENV_PATHS_ROOT="$(cygpath -w "$RENV_HOME" | tr '\\' '/')"
  export LOCAL_REPO="$(cygpath -w "$LOCAL_REPO" | tr '\\' '/')"
fi

# --- Run R install script
Rscript --vanilla "$SCRIPT_DIR/R/admin_R_install.R"
EXIT_CODE=$?

# Write the combined R_requirements.txt + r_version.txt hash that jrrun checks
# so it does not trigger a rebuild immediately after admin_install_R has run.
if [[ $EXIT_CODE -eq 0 ]]; then
  REQ_HASH=$(cat "$SCRIPT_DIR/R_requirements.txt" "$SCRIPT_DIR/r_version.txt" | shasum -a 256 | cut -d' ' -f1)
  echo "$REQ_HASH" > "$RENV_HOME/.renv_lock_hash"
fi
printf '%s\t%s\t%s\t%s\n' \
  "$(date '+%Y-%m-%dT%H:%M:%S')" \
  "$(basename "$0")" \
  "$*" \
  "$EXIT_CODE" >> "$ADMIN_LOG_FILE"
exit $EXIT_CODE
