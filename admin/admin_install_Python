#!/bin/bash
set -e
#
# admin_install_Python
# Sets up the validated Python environment.
#
# Usage:
#   admin_install_Python              — install from existing local repo
#   admin_install_Python --rebuild    — download all packages from PyPI, then install
#   admin_install_Python --add packagename==version
#                                     — add one package to existing repo, then install
#

# --- Script directory (admin/)
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR" || exit 1
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"

# --- Platform helpers
# shellcheck source=../bin/jr_platform.sh
source "$PROJECT_ROOT/bin/jr_platform.sh"

# --- Project identity — read from project_id.txt (one line change per fork)
PROJECT_ID_FILE="$SCRIPT_DIR/project_id.txt"
if [[ ! -f "$PROJECT_ID_FILE" ]]; then
  echo "❌ project_id.txt not found at: $PROJECT_ID_FILE"
  echo "   Contact your administrator."
  exit 1
fi
PROJECT_ID="$(tr -d '[:space:]' < "$PROJECT_ID_FILE")"

# --- Python environment path
export VENV_PATH="$HOME/.venvs/$PROJECT_ID"

# --- Local package repo and flags
export LOCAL_REPO="$(dirname "$SCRIPT_DIR")/Python_repo/my-repo"
export BUILD_REPO="${BUILD_REPO:-false}"
export ADD_PACKAGE=""

# --- Requirements file — exported so admin_python_install.py can read it
export REQ_FILE="$SCRIPT_DIR/python_requirements.txt"

# --- Help
show_help() {
  echo ""
  echo "Usage: admin_install_Python [--rebuild] [--add packagename==version]"
  echo ""
  echo "  (no flag)                  Install from existing local repo"
  echo "  --rebuild                  Download all packages from PyPI, then install"
  echo "  --add packagename==version Add one package to existing repo, then install"
  echo "  -h|--help                  Show this help message"
  echo ""
  echo "Examples:"
  echo "  admin_install_Python"
  echo "  admin_install_Python --rebuild"
  echo "  admin_install_Python --add scipy==1.11.0"
  echo ""
  exit 0
}

# --- Argument parsing
SKIP_NEXT=false
for arg in "$@"; do
  if [[ "$SKIP_NEXT" == "true" ]]; then
    export ADD_PACKAGE="$arg"
    SKIP_NEXT=false
    continue
  fi
  case "$arg" in
    -h|--help)  show_help ;;
    --rebuild)  export BUILD_REPO="true" ;;
    --add=*)    export ADD_PACKAGE="${arg#--add=}" ;;
    --add)      SKIP_NEXT=true ;;
    *)          echo "❌ Unknown argument: $arg"; show_help ;;
  esac
done

# --- Validate --add format if provided
if [[ -n "$ADD_PACKAGE" ]]; then
  if [[ "$ADD_PACKAGE" != *"=="* ]]; then
    echo "❌ --add requires format: packagename==version"
    echo "   Example: admin_install_Python --add scipy==1.11.0"
    exit 1
  fi
fi

# --- Check requirements file exists
if [[ ! -f "$REQ_FILE" ]]; then
  echo "❌ $REQ_FILE not found in $SCRIPT_DIR."
  echo "   Please create the file."
  exit 1
fi

# --- Check Python version file exists
PY_VERSION_FILE="$SCRIPT_DIR/python_version.txt"
if [[ ! -f "$PY_VERSION_FILE" ]]; then
  echo "❌ python_version.txt missing in $SCRIPT_DIR"
  echo "   Please create the file with full version e.g: 3.11.9"
  exit 1
fi
REQ_PYTHON="$(tr -d '[:space:]' < "$PY_VERSION_FILE")"
REQ_MAJOR_MINOR=$(echo "$REQ_PYTHON" | awk -F. '{print $1 "." $2}')
if [[ "$(jr_os)" == "windows" ]]; then
  PYTHON_BIN="python"
else
  PYTHON_BIN="python$REQ_MAJOR_MINOR"
fi

# --- Check Python is installed
if ! command -v "$PYTHON_BIN" >/dev/null 2>&1; then
  echo "❌ $PYTHON_BIN not found"
  echo "   Install Python from $(dirname "$SCRIPT_DIR")/Python_repo/"
  echo "   Double-click the .pkg and follow the installer steps."
  exit 1
fi

# --- Check Python version matches requirement
PY_VER=$("$PYTHON_BIN" - <<EOF
import sys
print(f"{sys.version_info.major}.{sys.version_info.minor}.{sys.version_info.micro}")
EOF
)
if [[ "$PY_VER" != "$REQ_PYTHON" ]]; then
  echo "❌ Python $REQ_PYTHON required, found $PY_VER"
  echo "   Install Python from $(dirname "$SCRIPT_DIR")/Python_repo"
  echo "   Double-click the .pkg and follow the installer steps."
  exit 1
else
  echo "✅ Correct Python version $PY_VER installed"
fi

# --- Confirm mode
if [[ "$BUILD_REPO" == "true" ]]; then
  echo "🔨 Mode: full rebuild from PyPI"
elif [[ -n "$ADD_PACKAGE" ]]; then
  echo "➕ Mode: add package to existing repo ($ADD_PACKAGE)"
else
  echo "📂 Mode: install from existing local repo"
fi
echo ""

# --- Admin log setup
ADMIN_LOG_FILE="$HOME/.jrscript/$PROJECT_ID/admin.log"
mkdir -p "$(dirname "$ADMIN_LOG_FILE")"

# --- Run Python admin install script using the validated Python binary
"$PYTHON_BIN" -I "$SCRIPT_DIR/Python/admin_python_install.py"
EXIT_CODE=$?
printf '%s\t%s\t%s\t%s\n' \
  "$(date '+%Y-%m-%dT%H:%M:%S')" \
  "$(basename "$0")" \
  "$*" \
  "$EXIT_CODE" >> "$ADMIN_LOG_FILE"
exit $EXIT_CODE
